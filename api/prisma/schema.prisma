// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ENUMS (El Sistema Lego)
// ==========================================

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  VERY_EASY
  EASY
  NORMAL
  HARD
  VERY_HARD
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum GameMode {
  ARCADE
  ROGUELITE
  DUEL
}

enum TriggerType {
  CURRENT_QUESTION // Ej: Elimina 1 opción ahora
  NEXT_QUESTION    // Ej: En la próxima, elimina 2
  PASSIVE          // Ej: +10% de bonus pasivo
  ROUND            // Ej: 1 pregunta extra en la ronda
}

enum ConditionType {
  NONE
  ON_WIN           // "Si aciertas..."
  ON_LOSS          // "Si fallas..."
  IS_CATEGORY      // "Si es de Categoría X..."
  IS_NOT_CATEGORY  // "Si no es de Categoría X..."
}

enum ActionType {
  REMOVE_OPTION
  EXTRA_CHANCE      // "Intentar 1 vez más"
  REVEAL_ANSWER
  MULTIPLY_TIME
  MULTIPLY_SCORE
  CHANGE_CATEGORY   // Cambiar la categoría de la pregunta
  ADD_QUESTION      // "1 pregunta extra en la ronda"
  REMOVE_QUESTION
}

// ==========================================
// 2. MODELOS PRINCIPALES
// ==========================================

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  password      String?   
  image         String?
  role          Role          @default(USER)
  
  coins         Int           @default(0)
  gems          Int           @default(0) 
  level         Int           @default(1)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions      GameSession[]
  inventory     UserCard[]    // NUEVO: El inventario del usuario
}

model Category {
  id               String   @id @default(cuid())
  key              String   @unique 
  tmdbId           Int?     
  
  createdAt        DateTime @default(now())
  cardsWithPowerUp Card[]   @relation("PowerUpCategory")
}

model Card {
  id               String   @id @default(cuid())
  tmdbId           Int      @unique
  title            String
  year             Int
  posterPath       String?
  rarity           Rarity   @default(COMMON)
  
  // === MATRIZ DE POWER-UPS (El Sistema Lego) ===
  powerUpTrigger   TriggerType?    
  powerUpCondition ConditionType?  
  powerUpAction    ActionType?     
  powerUpValue     Int?            
  
  targetCategoryId String?
  targetCategory   Category? @relation("PowerUpCategory", fields: [targetCategoryId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owners           UserCard[] // NUEVO: Usuarios que poseen esta carta
}

// NUEVO: LA BILLETERA DE CARTAS (Inventario y Mazo)
model UserCard {
  id          String   @id @default(cuid())
  userId      String
  cardId      String
  
  quantity    Int      @default(1) // Por si le sale repetida en un sobre
  level       Int      @default(1) // Por si a futuro se pueden mejorar
  isEquipped  Boolean  @default(false) // TRUE si la carta está en el mazo de las 5 activas
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, cardId]) // Evita que un usuario tenga dos filas de la misma carta
}

model Question {
  id            String     @id @default(cuid())
  text          String     
  correctAnswer String     
  options       String[]   
  difficulty    Difficulty
  cardId        String?    
  categories    String[]   
}

// ==========================================
// 3. HISTORIAL Y PARTIDAS
// ==========================================

model GameSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  mode        GameMode @default(ARCADE)
  score       Int      @default(0)
  auditLog    Json?    

  createdAt   DateTime @default(now())
}